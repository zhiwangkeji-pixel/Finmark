NODE_ENV=production
PORT=3000

# TuShare
TUSHARE_TOKEN=replace-with-your-tushare-token
TUSHARE_ENDPOINT=http://api.tushare.pro

# Gemini
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# First boot admin account. Change these before exposing the site publicly.
DEFAULT_ADMIN_USERNAME=beebee
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-password

# Use true when the app is served through HTTPS, for example Nginx + Certbot.
COOKIE_SECURE=true

# Optional old share-gate password. Leave empty when using the built-in login system only.
SHARE_USER=friend
SHARE_PASSWORD=

# Sync settings
SYNC_RETRY_MS=180000
AUTO_SYNC_CHECK_MS=300000
